#!/usr/bin/env sh
set -eu

SOURCE=$0
while [ -h "$SOURCE" ]; do
  SOURCE_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
  SOURCE_LINK=$(readlink "$SOURCE")
  case "$SOURCE_LINK" in
    /*) SOURCE=$SOURCE_LINK ;;
    *) SOURCE=$SOURCE_DIR/$SOURCE_LINK ;;
  esac
done

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
REPO_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
export YGG_HOME=${YGG_HOME:-$REPO_DIR}

if ! command -v python3 >/dev/null 2>&1; then
  printf '%s\n' "python3 is required for server-backed ygg-mcp." >&2
  exit 75
fi

exec python3 -S "$REPO_DIR/scripts/ygg-server-client.py" mcp "$@"
