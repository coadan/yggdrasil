#!/usr/bin/env sh
set -eu

SOURCE=$0
case "$SOURCE" in
  */*) ;;
  *) SOURCE=$(command -v "$SOURCE") ;;
esac
while [ -h "$SOURCE" ]; do
  SOURCE_PARENT=${SOURCE%/*}
  [ -n "$SOURCE_PARENT" ] || SOURCE_PARENT=/
  SOURCE_DIR=$(CDPATH= cd -- "$SOURCE_PARENT" && pwd)
  SOURCE_LINK=$(readlink "$SOURCE")
  case "$SOURCE_LINK" in
    /*) SOURCE=$SOURCE_LINK ;;
    *) SOURCE=$SOURCE_DIR/$SOURCE_LINK ;;
  esac
done

SOURCE_PARENT=${SOURCE%/*}
[ -n "$SOURCE_PARENT" ] || SOURCE_PARENT=/
case "$SOURCE_PARENT" in
  /*) SCRIPT_DIR=$SOURCE_PARENT ;;
  *) SCRIPT_DIR=$(CDPATH= cd -- "$SOURCE_PARENT" && pwd) ;;
esac
REPO_DIR=${SCRIPT_DIR%/*}
[ -n "$REPO_DIR" ] || REPO_DIR=/
export YGG_HOME=${YGG_HOME:-$REPO_DIR}

if ! command -v python3 >/dev/null 2>&1; then
  printf '%s\n' "python3 is required for server-backed ygg-mcp." >&2
  exit 75
fi

exec python3 -S "$REPO_DIR/scripts/ygg-server-client.py" mcp "$@"
