#!/usr/bin/env sh
set -eu

SOURCE=$0
while [ -h "$SOURCE" ]; do
  SOURCE_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
  SOURCE_LINK=$(readlink "$SOURCE")
  case "$SOURCE_LINK" in
    /*) SOURCE=$SOURCE_LINK ;;
    *) SOURCE=$SOURCE_DIR/$SOURCE_LINK ;;
  esac
done

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
REPO_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
EDN_REPO_DIR=$(printf '%s' "$REPO_DIR" | sed 's/\\/\\\\/g; s/"/\\"/g')
export AGRAPH_HOME=${AGRAPH_HOME:-$REPO_DIR}

exec clojure \
  -Srepro \
  -Sdeps "{:deps {local/agraph {:local/root \"$EDN_REPO_DIR\"}}}" \
  "-J-Dagraph.home=$AGRAPH_HOME" \
  -J--add-opens=java.base/java.nio=ALL-UNNAMED \
  -J--enable-native-access=ALL-UNNAMED \
  -J-Dio.netty.tryReflectionSetAccessible=true \
  -M \
  -m agraph.cli "$@"
