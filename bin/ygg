#!/usr/bin/env sh
set -eu

SOURCE=$0
while [ -h "$SOURCE" ]; do
  SOURCE_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
  SOURCE_LINK=$(readlink "$SOURCE")
  case "$SOURCE_LINK" in
    /*) SOURCE=$SOURCE_LINK ;;
    *) SOURCE=$SOURCE_DIR/$SOURCE_LINK ;;
  esac
done

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
REPO_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
EDN_REPO_DIR=$(printf '%s' "$REPO_DIR" | sed 's/\\/\\\\/g; s/"/\\"/g')
export YGG_HOME=${YGG_HOME:-$REPO_DIR}

MAIN=ygg.cli
if [ "${1:-}" = "daemon" ]; then
  if { [ "${2:-}" = "status" ] || [ "${2:-}" = "stop" ] || [ "${2:-}" = "query" ]; } && command -v python3 >/dev/null 2>&1; then
    shift
    python3 "$REPO_DIR/scripts/ygg-daemon-client.py" "$@"
    exit "$?"
  fi
  MAIN=ygg.daemon
  shift
elif [ "${1:-}" = "sync" ] && [ "${2:-}" = "inspect" ]; then
  shift 2
  if command -v python3 >/dev/null 2>&1; then
    set +e
    python3 "$REPO_DIR/scripts/ygg-daemon-client.py" sync-inspect "$@"
    STATUS=$?
    set -e
    if [ "$STATUS" -ne 75 ]; then
      exit "$STATUS"
    fi
  fi
  MAIN=ygg.cli-sync-inspect
elif [ "${1:-}" = "query" ]; then
  shift
  if command -v python3 >/dev/null 2>&1; then
    set +e
    python3 "$REPO_DIR/scripts/ygg-daemon-client.py" query "$@"
    STATUS=$?
    set -e
    if [ "$STATUS" -ne 75 ]; then
      exit "$STATUS"
    fi
  fi
  set -- query "$@"
fi

exec clojure \
  -Srepro \
  -Sdeps "{:deps {local/ygg {:local/root \"$EDN_REPO_DIR\"}}}" \
  "-J-Dygg.home=$YGG_HOME" \
  -J--add-opens=java.base/java.nio=ALL-UNNAMED \
  -J--enable-native-access=ALL-UNNAMED \
  -J-Dio.netty.tryReflectionSetAccessible=true \
  -M \
  -m "$MAIN" "$@"
