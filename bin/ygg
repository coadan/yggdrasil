#!/usr/bin/env sh
set -eu

SOURCE=$0
while [ -h "$SOURCE" ]; do
  SOURCE_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
  SOURCE_LINK=$(readlink "$SOURCE")
  case "$SOURCE_LINK" in
    /*) SOURCE=$SOURCE_LINK ;;
    *) SOURCE=$SOURCE_DIR/$SOURCE_LINK ;;
  esac
done

SCRIPT_DIR=$(CDPATH= cd -- "$(dirname -- "$SOURCE")" && pwd)
REPO_DIR=$(CDPATH= cd -- "$SCRIPT_DIR/.." && pwd)
export YGG_HOME=${YGG_HOME:-$REPO_DIR}
NATIVE_SERVER=${YGG_NATIVE_SERVER:-$REPO_DIR/target/native/ygg-server}

if [ "$#" -eq 0 ] || [ "${1:-}" = "help" ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  cat <<'EOF'
Usage: ygg start | ygg <command> ...

Server:
  start                 Start the local Yggdrasil server.
  service start-at-login enable|disable|status
                        Manage user-login server startup.
  status [--json]       Show server and project status.
  stop                  Stop the local server.

Project:
  init                  Initialize a project reference and warm the service.
  sync                  Sync or inspect a project.
  query                 Query the current graph.
  view                  Render graph slices.
  packages              Report package/dependency evidence.
  maintenance           Manage scheduled maintenance.
  corrections           Manage accepted graph corrections.
  agent                 Install or remove agent guidance.
EOF
  exit 0
elif [ "${1:-}" = "start" ]; then
  if [ "$#" -gt 1 ]; then
    printf '%s\n' "ygg start starts the local server and does not accept project setup arguments." >&2
    printf '%s\n' "Use ygg init --sync for project setup." >&2
    exit 2
  fi
  if command -v python3 >/dev/null 2>&1; then
    if YGG_SERVER_CONNECT_TIMEOUT_MS=0 python3 "$REPO_DIR/scripts/ygg-server-client.py" status >/dev/null 2>&1; then
      printf '%s\n' "Yggdrasil server is already running."
      exit 0
    fi
  fi
  if [ -x "$NATIVE_SERVER" ]; then
    exec "$NATIVE_SERVER" start
  fi
  set -- start
elif [ "$#" -gt 0 ] && command -v python3 >/dev/null 2>&1; then
  exec python3 "$REPO_DIR/scripts/ygg-server-client.py" "$@"
elif [ "$#" -gt 0 ]; then
  printf '%s\n' "python3 is required for server-backed ygg commands." >&2
  exit 75
fi

EDN_REPO_DIR=$(printf '%s' "$REPO_DIR" | sed 's/\\/\\\\/g; s/"/\\"/g')

exec clojure \
  -Srepro \
  -Sdeps "{:deps {local/ygg {:local/root \"$EDN_REPO_DIR\"}}}" \
  "-J-Dygg.home=$YGG_HOME" \
  -J--add-opens=java.base/java.nio=ALL-UNNAMED \
  -J--enable-native-access=ALL-UNNAMED \
  -J-Dio.netty.tryReflectionSetAccessible=true \
  -M \
  -m ygg.server "$@"
