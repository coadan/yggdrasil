{
  "asyncapi": "3.0.0",
  "info": {
    "title": "Panel Events",
    "version": "1.0.0"
  },
  "servers": {
    "production": {
      "url": "broker.example.test",
      "protocol": "amqp"
    }
  },
  "channels": {
    "panel.created": {
      "address": "panel.created",
      "bindings": {
        "amqp": {
          "is": "routingKey"
        }
      },
      "publish": {
        "operationId": "publishPanelCreated",
        "traits": [
          {
            "$ref": "#/components/operationTraits/secured"
          }
        ],
        "message": {
          "$ref": "#/components/messages/PanelCreated"
        }
      }
    }
  },
  "components": {
    "operationTraits": {
      "secured": {
        "bindings": {
          "amqp": {
            "ack": true
          }
        }
      }
    },
    "messages": {
      "PanelCreated": {
        "headers": {
          "$ref": "#/components/schemas/EventHeaders"
        },
        "correlationId": {
          "location": "$message.header#/correlationId"
        },
        "payload": {
          "$ref": "#/components/schemas/Panel"
        },
        "bindings": {
          "amqp": {
            "contentEncoding": "gzip"
          }
        }
      }
    },
    "schemas": {
      "Panel": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          }
        }
      },
      "EventHeaders": {
        "type": "object",
        "properties": {
          "correlationId": {
            "type": "string"
          }
        }
      }
    }
  }
}
