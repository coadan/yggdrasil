datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

model User {
  id     String  @id @map("user_id")
  email  String  @unique
  panels Panel[]

  @@map("users")
}

model Panel {
  id      String @id
  owner   User   @relation(fields: [ownerId], references: [id])
  ownerId String
  status  PanelStatus

  @@index([ownerId])
  @@unique([ownerId, status])
  @@map("panels")
}

enum PanelStatus {
  DRAFT
  LIVE
}
