{:tasks
 {:requires ([babashka.process :refer [shell]])
  :init (defn ygg [& args] (apply shell "./bin/ygg" args))

  start {:doc "Start the local Yggdrasil server. Usage: bb start"
         :task (apply ygg "start" *command-line-args*)}

  init {:doc "Initialize a project. Usage: bb init <repo-root> [--project ID] [--out project.edn] [--sync]"
        :task (apply ygg "init" *command-line-args*)}

  status {:doc "Show local Yggdrasil server status. Usage: bb status [--json]"
          :task (apply ygg "status" *command-line-args*)}

  stop {:doc "Stop the local Yggdrasil server for upgrades or explicit shutdown. Usage: bb stop"
        :task (apply ygg "stop" *command-line-args*)}

  sync {:doc "Sync Yggdrasil with a project. Usage: bb sync [<project.edn>] [--project ID] [--check] [--enqueue] [--query-index]"
        :task (apply ygg "sync" *command-line-args*)}

  maintenance {:doc "Manage auto maintenance. Usage: bb maintenance status|enable|disable|schedule|worker|candidates|classify ..."
               :task (apply ygg "maintenance" *command-line-args*)}

  server:dev {:doc "Start the reloadable dev server. Usage: bb server:dev"
              :task (apply shell "clojure" "-M:dev" "-m" "ygg.dev.server"
                           *command-line-args*)}

  query {:doc "Query the current graph. Usage: bb query \"text\" [--project ID]"
         :task (apply ygg "query" *command-line-args*)}

  view {:doc "Render or export graph slices. Usage: bb view overview|deps|query|systems ..."
        :task (apply ygg "view" *command-line-args*)}

  packages {:doc "Report package/dependency evidence. Usage: bb packages [--project ID] [--repo ID] [--ecosystem npm|cargo|go] [--package NAME] [--with-conflicts] [--without-import-evidence] [--limit N] [--json]"
            :task (apply ygg "packages" *command-line-args*)}

  bench {:doc "Run issue replay benchmarks. Usage: bb bench prepare|agent-packet|agent-baseline|agent-run|agent-score|agent-report|agent-check|claim-pack|improve|run|report|show <benchmark.edn>"
         :task (apply ygg "bench" *command-line-args*)}

  headline {:doc "Run the architecture-first headline benchmark workflow. Usage: bb headline baseline|codebase-memory|external-baselines|shell-only|prepare-ygg|ygg|agents|reports|token-check|compare|claim-pack|all [--suite PATH] [--out DIR] [--agent ID] [--command CMD] [--dry-run]"
            :task (apply shell "bash" "scripts/headline-bench.sh"
                         *command-line-args*)}

  agent-efficiency {:doc "Run the broad shell-only vs Yggdrasil agent-efficiency workflow. Usage: bb agent-efficiency all|agents|reports|token-check|claim-pack [options]"
                    :task (apply shell "bash" "scripts/agent-efficiency-bench.sh"
                                 *command-line-args*)}

  bench:gate {:doc "Run the deterministic tracked benchmark gate. Usage: bb bench:gate [--suite PATH] [--manifest PATH] [--out DIR] [--case ID|--cases IDS] [--setup-check] [--check-only] [--fresh-context] [--skip-setup-check] [--dry-run]"
              :task (let [{:keys [exit]} (apply shell
                                                {:continue true}
                                                "bash"
                                                "scripts/benchmark-gate.sh"
                                                *command-line-args*)]
                      (System/exit exit))}

  bench:claim-quick {:doc "Run the small non-synthetic claim-readiness gate. Usage: bb bench:claim-quick [--check-only] [--fresh-context] [--skip-existing] [--setup-check] [--case ID|--cases IDS] [--dry-run]"
                     :task (let [{:keys [exit]} (apply shell
                                                       {:continue true}
                                                       "bash"
                                                       "scripts/claim-quick-gate.sh"
                                                       *command-line-args*)]
                             (System/exit exit))}

  prompt-token-gate {:doc "Validate prompt-token reduction from a prompt-token measure report. Usage: bb prompt-token-gate REPORT [--min-shared-cases N] [--out PATH]"
                     :task (let [{:keys [exit]} (apply shell
                                                       {:continue true}
                                                       "python3"
                                                       "scripts/prompt-token-gate.py"
                                                       *command-line-args*)]
                             (System/exit exit))}

  stage-time-gate {:doc "Validate completed benchmark stage timings from agent reports. Usage: bb stage-time-gate REPORT... [--baseline-report REPORT] [--max-case-stage-ms N] [--max-total-stage-ms N] [--max-case-stage-regression-ms N] [--max-total-stage-regression-ms N] [--max-case-stage-regression-ratio N] [--max-total-stage-regression-ratio N] [--min-stage-regression-ms N] [--stage NAME] [--out PATH]"
                   :task (let [{:keys [exit]} (apply shell
                                                     {:continue true}
                                                     "python3"
                                                     "scripts/stage-time-gate.py"
                                                     *command-line-args*)]
                           (System/exit exit))}

  v1:smoke {:doc "Run the V1 install/start/report smoke gate. Usage: bb v1:smoke [--keep]"
            :task (apply shell "bash" "scripts/v1-smoke.sh"
                         *command-line-args*)}

  v1:gate {:doc "Run the V1 release-readiness gate: test, lint, format, report UI, and install/start smoke."
           :task (do
                   (shell "clojure -M:test")
                   (shell "clojure -M:lint")
                   (shell "clojure -M:format/check")
                   (shell {:dir "report-ui"} "npm test")
                   (shell {:dir "report-ui"} "npm run build")
                   (shell "bash scripts/v1-smoke.sh"))}

  graalvm:args {:doc "Print the GraalVM native-image command for the ygg server."
                :task (shell "clojure -T:build native-args")}

  graalvm:uber {:doc "Build the standalone ygg server jar used by native-image."
                :task (shell "clojure -T:build uber")}

  graalvm:check {:doc "Check that GraalVM native-image is available."
                 :task (shell "clojure -T:build native-check")}

  graalvm:native {:doc "Build target/native/ygg-server with GraalVM native-image. Requires native-image or NATIVE_IMAGE."
                  :task (shell "clojure -T:build native")}

  graalvm:docker-check {:doc "Check the Docker-backed GraalVM native-image builder."
                        :task (shell "clojure -T:build native-docker-check")}

  graalvm:docker-native {:doc "Build target/native/ygg-server-linux with the Docker-backed GraalVM native-image builder."
                         :task (shell "clojure -T:build native-docker")}

  embed {:doc "Embed search docs. Usage: bb embed [--model MODEL] [--limit N]"
         :task (apply ygg "embed" *command-line-args*)}

  report {:doc "Write a local report bundle. Usage: bb report [<project.edn>] [--project ID] [--out ygg-out]"
          :task (apply ygg "report" *command-line-args*)}

  plugin {:doc "Manage Yggdrasil plugin packages. Usage: bb plugin new|validate|diagnose|dry-run|install|list|remove|registry ..."
          :task (apply ygg "plugin" *command-line-args*)}

  report-ui:install {:doc "Install report UI dependencies."
                     :task (shell {:dir "report-ui"} "npm install")}

  report-ui:build {:doc "Build the React/MDX report UI into resources."
                   :task (shell {:dir "report-ui"} "npm run build")}

  report-ui:test {:doc "Run report UI tests."
                  :task (shell {:dir "report-ui"} "npm test")}

  report-ui:dev {:doc "Run the report UI dev server."
                 :task (apply shell {:dir "report-ui"} "npm run dev"
                              *command-line-args*)}

  large-files {:doc "Audit tracked files over a line limit. Usage: bb large-files [limit]"
               :task (apply shell "bash" "scripts/large-file-audit.sh"
                            *command-line-args*)}

  test {:doc "Run tests."
        :task (shell "clojure -M:test")}

  lint {:doc "Run clj-kondo."
        :task (shell "clojure -M:lint")}

  format:check {:doc "Check formatting."
                :task (shell "clojure -M:format/check")}

  format:fix {:doc "Fix formatting."
              :task (shell "clojure -M:format/fix")}}}
